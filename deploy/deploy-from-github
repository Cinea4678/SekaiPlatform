#!/usr/bin/env bash
set -euo pipefail

DEPLOY_DIR="${DEPLOY_DIR:-/opt/sekai-platform}"
SERVER_ENV_FILE="${SERVER_ENV_FILE:-/etc/sekai-platform/server.env}"
REGISTRY="${REGISTRY:-ghcr.io}"
PROJECT_NAME="${PROJECT_NAME:-sekai-platform}"
GITHUB_REPOSITORY="${GITHUB_REPOSITORY:-}"
COMPOSE_PATH="${COMPOSE_PATH:-deploy/compose.server.yml}"
IMAGE_PREFIX="${IMAGE_PREFIX:-}"
IMAGE_TAG="${IMAGE_TAG:-}"
DRY_RUN=0

usage() {
  cat <<'USAGE'
Usage:
  deploy-from-github --repository owner/repo --image-prefix ghcr.io/owner/repo --image-tag <sha>

Options:
  --repository VALUE     GitHub repository in owner/repo form. Defaults to owner/repo parsed from image prefix.
  --image-prefix VALUE   Container image prefix, for example ghcr.io/owner/repo.
  --image-tag VALUE      Container image tag to deploy.
  --compose-path VALUE   Compose file path inside the repository. Default: deploy/compose.server.yml.
  --deploy-dir VALUE     Runtime directory. Default: /opt/sekai-platform.
  --env-file VALUE       Server env file. Default: /etc/sekai-platform/server.env.
  --registry VALUE       Container registry. Default: ghcr.io.
  --dry-run              Validate inputs and render files without pulling or restarting.
  -h, --help             Show this help.
USAGE
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repository)
      GITHUB_REPOSITORY="${2:-}"
      shift 2
      ;;
    --image-prefix)
      IMAGE_PREFIX="${2:-}"
      shift 2
      ;;
    --image-tag)
      IMAGE_TAG="${2:-}"
      shift 2
      ;;
    --compose-path)
      COMPOSE_PATH="${2:-}"
      shift 2
      ;;
    --deploy-dir)
      DEPLOY_DIR="${2:-}"
      shift 2
      ;;
    --env-file)
      SERVER_ENV_FILE="${2:-}"
      shift 2
      ;;
    --registry)
      REGISTRY="${2:-}"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      printf 'Unknown option: %s\n' "$1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'Required command not found: %s\n' "$1" >&2
    exit 1
  fi
}

require_value() {
  local name="$1"
  local value="$2"
  if [[ -z "$value" ]]; then
    printf '%s is required.\n' "$name" >&2
    exit 1
  fi
}

require_command docker
require_command curl
require_value IMAGE_PREFIX "$IMAGE_PREFIX"
require_value IMAGE_TAG "$IMAGE_TAG"

if [[ -z "$GITHUB_REPOSITORY" ]]; then
  GITHUB_REPOSITORY="${IMAGE_PREFIX#"$REGISTRY"/}"
fi

require_value GITHUB_REPOSITORY "$GITHUB_REPOSITORY"
require_value COMPOSE_PATH "$COMPOSE_PATH"

if [[ ! -f "$SERVER_ENV_FILE" ]]; then
  printf 'Server env file not found: %s\n' "$SERVER_ENV_FILE" >&2
  exit 1
fi

umask 077
mkdir -p "$DEPLOY_DIR"
lock_dir="$DEPLOY_DIR/deploy.lock"
if ! mkdir "$lock_dir" 2>/dev/null; then
  printf 'Another deployment is already running.\n' >&2
  exit 1
fi

compose_file="$DEPLOY_DIR/compose.yml"
env_file="$DEPLOY_DIR/.env"
tmp_compose="$(mktemp "$DEPLOY_DIR/compose.yml.tmp.XXXXXX")"
tmp_env="$(mktemp "$DEPLOY_DIR/.env.tmp.XXXXXX")"

cleanup() {
  rm -f "$tmp_compose" "$tmp_env"
  rmdir "$lock_dir" 2>/dev/null || true
}
trap cleanup EXIT

download_compose() {
  local url="https://raw.githubusercontent.com/$GITHUB_REPOSITORY/$IMAGE_TAG/$COMPOSE_PATH"

  printf 'Downloading compose file. repository=%s path=%s ref=%s\n' "$GITHUB_REPOSITORY" "$COMPOSE_PATH" "$IMAGE_TAG"
  curl -fsSL "$url" -o "$tmp_compose"
}

render_env() {
  cp "$SERVER_ENV_FILE" "$tmp_env"
  {
    printf '\n'
    printf 'SEKAI_IMAGE_PREFIX=%s\n' "$IMAGE_PREFIX"
    printf 'SEKAI_IMAGE_TAG=%s\n' "$IMAGE_TAG"
  } >> "$tmp_env"
}

run_compose() {
  docker compose --project-directory "$DEPLOY_DIR" -f "$compose_file" "$@"
}

printf 'Preparing deployment. image_prefix=%s image_tag=%s deploy_dir=%s\n' "$IMAGE_PREFIX" "$IMAGE_TAG" "$DEPLOY_DIR"
download_compose
render_env
mv "$tmp_compose" "$compose_file"
mv "$tmp_env" "$env_file"
chmod 600 "$env_file"

run_compose config --quiet

if [[ "$DRY_RUN" == "1" ]]; then
  printf 'Dry run completed.\n'
  exit 0
fi

run_compose pull
run_compose up -d --remove-orphans
run_compose ps

printf 'Deployment completed. image_tag=%s\n' "$IMAGE_TAG"
