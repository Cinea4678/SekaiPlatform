{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=sekai_platform;Username=sekai_platform;Password=sekai_platform"
  },
  "Elasticsearch": {
    "Url": "http://localhost:9200",
    "IndexName": "sekai-language-assets-v1",
    "BulkBatchSize": 1000
  },
  "Jwt": {
    "Issuer": "sekai-platform",
    "Audience": "sekai-platform",
    "SigningKey": "replace-with-local-development-signing-key"
  },
  "InternalAuth": {
    "Issuer": "sekai-platform-internal",
    "Actor": "search-service",
    "PublicKeys": {
      "api-service": "",
      "asset-service": "",
      "sync-worker": ""
    }
  },
  "AllowedHosts": "*"
}
