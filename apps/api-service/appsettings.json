{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=sekai_platform;Username=sekai_platform;Password=sekai_platform"
  },
  "Elasticsearch": {
    "Url": "http://localhost:9200"
  },
  "InternalServices": {
    "AuthService": "http://localhost:8081",
    "AssetService": "http://localhost:8082",
    "SearchService": "http://localhost:8083"
  },
  "Jwt": {
    "Issuer": "sekai-platform",
    "Audience": "sekai-platform",
    "SigningKey": "replace-with-local-development-signing-key"
  },
  "InternalAuth": {
    "Issuer": "sekai-platform-internal",
    "Actor": "api-service",
    "PrivateKeyPkcs8": "",
    "PublicKeys": {
      "api-service": "",
      "asset-service": "",
      "sync-worker": ""
    }
  },
  "Database": {
    "AutoMigrate": false,
    "Seed": false
  },
  "AllowedHosts": "*"
